					var ny = current.y + dy;
					if ( !isWalkable( arguments.grid, nx, ny ) ) {
						continue;
					}
					var key = nx & "," & ny;
					if ( blockedKeys.keyExists( key ) ) {
						continue;
					}
					if ( visited.keyExists( key ) ) {
