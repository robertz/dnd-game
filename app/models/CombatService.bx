/**
 * Turn-based grid combat rules engine, per the D&D 5e SRD 5.2.1 core rules.
 *
 * Stateless with respect to WireBox (registered as a singleton, holds no
 * per-encounter data itself) — every method takes the encounter's mutable
 * `state` struct (or the specific combatant structs it needs) and mutates
 * them in place, the same way the CBWIRE component's own data properties
 * work. This keeps the service usable from any wire component without
 * fighting CBWIRE's reactive data-binding model.
 */
class singleton {

	// Character Advancement table: XP required to reach each level (index = level).
	XP_THRESHOLDS = [
		0, 300, 900, 2700, 6500, 14000, 23000, 34000, 48000, 64000,
		85000, 100000, 120000, 140000, 165000, 195000, 225000, 265000, 305000, 355000
	];

	// Full-caster Spell Slots by level (index = level, value = slots per spell
	// level 1-9). Warlock uses Pact Magic, mechanically simplified here to the
	// same table (Warlocks actually have fewer, higher-level slots that
	// recharge on a Short Rest — not modeled, since this app has no rest UI).
	SPELL_SLOTS_FULL_CASTER = [
		[ 2 ], [ 3 ], [ 4, 2 ], [ 4, 3 ], [ 4, 3, 2 ], [ 4, 3, 3 ], [ 4, 3, 3, 1 ], [ 4, 3, 3, 2 ],
		[ 4, 3, 3, 3, 1 ], [ 4, 3, 3, 3, 2 ], [ 4, 3, 3, 3, 2, 1 ], [ 4, 3, 3, 3, 2, 1 ],
		[ 4, 3, 3, 3, 2, 1, 1 ], [ 4, 3, 3, 3, 2, 1, 1 ], [ 4, 3, 3, 3, 2, 1, 1, 1 ], [ 4, 3, 3, 3, 2, 1, 1, 1 ],
		[ 4, 3, 3, 3, 2, 1, 1, 1, 1 ], [ 4, 3, 3, 3, 3, 1, 1, 1, 1 ], [ 4, 3, 3, 3, 3, 2, 1, 1, 1 ], [ 4, 3, 3, 3, 3, 2, 2, 1, 1 ]
	];
	// Half-caster (Paladin, Ranger) Spell Slots by level: no slots at level 1,
	// first slot at level 2, per the "Spell Slots by Level" progression.
	SPELL_SLOTS_HALF_CASTER = [
		[], [ 2 ], [ 3 ], [ 3 ], [ 4, 2 ], [ 4, 2 ], [ 4, 3 ], [ 4, 3 ],
		[ 4, 3, 2 ], [ 4, 3, 2 ], [ 4, 3, 3 ], [ 4, 3, 3 ],
		[ 4, 3, 3, 1 ], [ 4, 3, 3, 1 ], [ 4, 3, 3, 2 ], [ 4, 3, 3, 2 ],
		[ 4, 3, 3, 3, 1 ], [ 4, 3, 3, 3, 1 ], [ 4, 3, 3, 3, 2 ], [ 4, 3, 3, 3, 2 ]
	];

	FULL_CASTER_CLASSES = [ "Bard", "Cleric", "Druid", "Sorcerer", "Warlock", "Wizard" ];
	HALF_CASTER_CLASSES = [ "Paladin", "Ranger" ];
	SPELLCASTING_ABILITY_BY_CLASS = {
		"Bard": "cha", "Cleric": "wis", "Druid": "wis", "Sorcerer": "cha", "Warlock": "cha", "Wizard": "int",
		"Paladin": "cha", "Ranger": "wis"
	};

	// Each spellcasting class's default cantrip is now looked up from the real
	// spells table (via _lookupClassSpell(), level 0), same as the 1st-level
	// spell — the SRD import originally had a regex bug that silently
	// dropped every level-0 spell, since cantrips are subtitled differently
	// ("Evocation Cantrip (...)") than leveled spells ("Level 3 Evocation
	// (...)"); fixed in import_srd.py and backfilled via seeds/cantrips_seed.sql.
	// Several classes have more than one usable attack/save cantrip in the
	// data (Wizard alone has Chill Touch, Fire Bolt, Poison Spray, Ray of
	// Frost, and Shocking Grasp) — this picks each class's most iconic one
	// when it's available, purely so the game keeps its familiar flavor,
	// not because the alternatives are wrong.
	ICONIC_CANTRIP_BY_CLASS = {
		"Wizard": "Fire Bolt", "Sorcerer": "Fire Bolt", "Warlock": "Eldritch Blast",
		"Druid": "Produce Flame", "Cleric": "Sacred Flame", "Bard": "Vicious Mockery"
	};

	// Classes whose 1st-level spell should favor a heal over a damage spell,
	// when _lookupClassSpell() finds both available — mirrors real-world
	// party-role expectations (a Cleric would rather have Cure Wounds ready
	// than Guiding Bolt as their one prepared leveled spell), not a rule from
	// the SRD itself.
	HEAL_PREFERRING_CLASSES = [ "Bard", "Cleric", "Druid", "Paladin", "Ranger" ];

	/**
	 * Decides and performs the player's action for one turn: move toward the
	 * opponent if not adjacent (preferring melee — better damage, no
	 * Disadvantage), then attack with whatever's in range once movement
	 * settles. Does not advance to the enemy's turn — callers do that
	 * separately once they're done acting.
	 *
	 * @state The encounter's full mutable game state struct.
	 */
	function playerDecideAndAct( state ) {
		var player = arguments.state.player;
		if ( !structKeyExists( arguments.state, "attacksUsedThisTurn" ) ) {
			arguments.state.attacksUsedThisTurn = 0;
		}
		var totalAttacks = attacksPerTurn( player );

		while ( arguments.state.attacksUsedThisTurn < totalAttacks && !arguments.state.gameOver ) {
			arguments.state.opponent = _nearestLivingOpponent( arguments.state );
			if ( isNull( arguments.state.opponent ) ) {
				return;
			}
			var opponent = arguments.state.opponent;
			var distance = chebyshev( player, opponent );

			if ( distance > 1 ) {
				var startPosition = { "x": player.position.x, "y": player.position.y };
				var steps = moveToward(
					player, opponent, arguments.state.movementRemaining, _stateGrid( arguments.state ),
					_otherLivingPositions( arguments.state, player, opponent )
				);
				if ( steps > 0 ) {
					arguments.state.movementRemaining -= steps;
					arguments.state.log.prepend( "#player.name# advances toward #opponent.name#." );
					checkOpportunityAttacks( arguments.state, player, true, startPosition );
					if ( arguments.state.gameOver ) {
						return;
					}
				}
				distance = chebyshev( player, opponent );
			}

			var choice = pickWeaponForDistance( player, distance, _stateGrid( arguments.state ), opponent.position );
			if ( isNull( choice ) ) {
				arguments.state.log.prepend( "#player.name# can't reach #opponent.name# this turn." );
				return;
			}

			arguments.state.attacksUsedThisTurn += 1;
			arguments.state.actionUsed = true;
			playerAttack( arguments.state, choice.weapon, choice.disadvantage );
		}
	}

	/**
	 * Resolves the player's attack against the opponent and, on a kill, ends
	 * the encounter and awards the opponent's XP to the player's saved
	 * character. Shared by the manual Attack action and the auto-battle
	 * player turn, so victory/XP handling only lives in one place.
	 *
	 * @state The encounter's full mutable game state struct.
	 * @weapon The weapon item being used for this attack.
	 * @disadvantage Whether this attack roll has Disadvantage.
	 */
	function playerAttack( state, weapon, disadvantage = false ) {
		var player = arguments.state.player;
		var opponent = arguments.state.opponent;
		resolveAttack( arguments.state.log, player, opponent, arguments.weapon, arguments.disadvantage, false, false, coverBonus( arguments.state, player, opponent ) );
		_checkDefenderDefeated( arguments.state, player, opponent, false );
	}

	/**
	 * Hands control to the enemy, then resets for the next player turn.
	 *
	 * @state The encounter's full mutable game state struct.
	 */
	function endPlayerTurn( state ) {
		arguments.state.currentTurn = "enemy";
		runEnemyTurn( arguments.state );

		if ( !arguments.state.gameOver ) {
			arguments.state.round += 1;
			arguments.state.currentTurn = "player";
			startNewRound( arguments.state );
		}
	}

	/**
	 * Resets everything that recharges at the top of a new round: the
	 * player's movement and Action/Bonus Action/Reaction economy, and every
	 * living combatant's Reaction (used for opportunity attacks — see
	 * checkOpportunityAttacks()). Shared by endPlayerTurn() and the wire
	 * component's auto-battle loop so the reset logic only lives in one place.
	 *
	 * @state The encounter's full mutable game state struct.
	 */
	function startNewRound( state ) {
		arguments.state.movementRemaining = int( arguments.state.player.speed / 5 );
		arguments.state.actionUsed = false;
		arguments.state.bonusActionUsed = false;
		arguments.state.attacksUsedThisTurn = 0;
		arguments.state.player.reactionUsed = false;
		for ( var opponent in _stateOpponents( arguments.state ) ) {
			opponent.reactionUsed = false;
		}
	}

	/**
	 * How many weapon attacks the Attack action grants this combatant in one
	 * turn — 1 normally, or more with the Extra Attack class feature line
	 * (Fighter's own progression goes further than other classes': Extra
	 * Attack at 5th grants a 2nd attack, "Two Extra Attacks" at 11th a 3rd,
	 * "Three Extra Attacks" at 20th a 4th — each tier is additive with the
	 * ones before it, matching how class_features accumulates them in
	 * `player.features` as the character levels up).
	 */
	function attacksPerTurn( combatant ) {
		if ( !structKeyExists( arguments.combatant, "features" ) ) {
			return 1;
		}
		var total = 1;
		if ( arrayFindNoCase( arguments.combatant.features, "Extra Attack" ) > 0 ) {
			total += 1;
		}
		if ( arrayFindNoCase( arguments.combatant.features, "Two Extra Attacks" ) > 0 ) {
			total += 1;
		}
		if ( arrayFindNoCase( arguments.combatant.features, "Three Extra Attacks" ) > 0 ) {
			total += 1;
		}
		return total;
	}

	/**
	 * Resolves opportunity attacks triggered by `mover` leaving a hostile
	 * combatant's reach: any living hostile that was adjacent to
	 * `startPosition` and is no longer adjacent to `mover`'s new position gets
	 * one free melee attack against them, using their Reaction (tracked via
	 * `reactionUsed`, reset each round by startNewRound()) — provided they
	 * have an equipped melee weapon. Simplified to only look at the start and
	 * end position (not every square crossed mid-move) and to ignore the
	 * Disengage action and reach weapons, neither of which this app models.
	 *
	 * @state The encounter's full mutable game state struct.
	 * @mover The combatant who just moved.
	 * @moverIsPlayer Whether `mover` is `state.player` — decides which side's living combatants are checked as potential attackers.
	 * @startPosition Where `mover` was standing before this move ({x, y}).
	 */
	function checkOpportunityAttacks( state, mover, moverIsPlayer, startPosition ) {
		var hostiles = arguments.moverIsPlayer ? _stateOpponents( arguments.state ) : [ arguments.state.player ];
		var moverAtStart = { "position": arguments.startPosition };

		for ( var hostile in hostiles ) {
			if (
				hostile.hitPoints <= 0 ||
				( structKeyExists( hostile, "reactionUsed" ) && hostile.reactionUsed ) ||
				chebyshev( moverAtStart, hostile ) > 1 ||
				chebyshev( arguments.mover, hostile ) <= 1
			) {
				continue;
			}
			var melee = equippedWeapon( hostile, "melee" );
			if ( isNull( melee ) ) {
				continue;
			}
			hostile.reactionUsed = true;
			arguments.state.log.prepend( "#hostile.name# makes an opportunity attack as #arguments.mover.name# moves away!" );
			resolveAttack( arguments.state.log, hostile, arguments.mover, melee, false, false, false, coverBonus( arguments.state, hostile, arguments.mover ) );
			_checkDefenderDefeated( arguments.state, hostile, arguments.mover, arguments.moverIsPlayer );
			if ( arguments.state.gameOver ) {
				return;
			}
		}
	}

	/**
	 * Runs every living opponent's turn in sequence (via _runOneOpponentTurn()),
	 * stopping early if the player goes down mid-sequence. For a single-mob
	 * state (no `state.opponents` array), this runs exactly the one opponent's
	 * turn, same as before multi-mob support existed.
	 *
	 * @state The encounter's full mutable game state struct.
	 */
	function runEnemyTurn( state ) {
		for ( var opponent in _stateOpponents( arguments.state ) ) {
			if ( opponent.hitPoints <= 0 ) {
				continue;
			}
			_runOneOpponentTurn( arguments.state, opponent );
			if ( arguments.state.gameOver ) {
				return;
			}
		}
	}

	/**
	 * Simple enemy AI for one opponent's turn: closes the distance greedily
	 * (1 square per step, up to its Speed). If the opponent knows any spells
	 * (the same knownCantrip/knownLeveledSpell fields loadCharacter() assigns
	 * the player — nothing grants these to monsters yet except the Priest
	 * Acolyte, so this is otherwise latent capability), it prefers
	 * self-healing when bloodied, then a damage spell with a clear line to
	 * the player, before falling back to melee/ranged weapons; if it still
	 * can't reach melee this turn, it falls back to a ranged weapon if in range.
	 *
	 * Does nothing at all — no movement, no attack — until the opponent has
	 * actually perceived the player (a clear line of sight to them, via
	 * hasLineOfSight()), tracked on `opponent.aware`. A mob stays dormant
	 * behind a wall or around a corner until the player wanders into view,
	 * rather than always beelining for them the instant combat starts.
	 * Without a grid (state has no walls to hide behind — e.g. the unit
	 * tests), every opponent is aware from the start.
	 *
	 * @state The encounter's full mutable game state struct.
	 * @opponent The specific opponent whose turn this is.
	 */
	private function _runOneOpponentTurn( state, opponent ) {
		var player = arguments.state.player;
		var grid = _stateGrid( arguments.state );

		if ( !structKeyExists( arguments.opponent, "aware" ) ) {
			arguments.opponent.aware = false;
		}
		if ( !arguments.opponent.aware ) {
			if ( !isNull( grid ) && !hasLineOfSight( grid, arguments.opponent.position, player.position ) ) {
				return;
			}
			arguments.opponent.aware = true;
			arguments.state.log.prepend( "#arguments.opponent.name# notices you!" );
		}

		// A player at 0 HP — dying, or merely stabilized — is Unconscious and
		// helpless: an aware opponent just finishes them off rather than
		// rolling a normal attack. This always lands, and counts as 2 failed
		// death saves if delivered within 5 feet (RAW: melee attacks — and any
		// attack at all, per the simplified 2024 Incapacitated rule — auto-crit
		// an unconscious target at that range). Landing a further hit on a
		// stabilized player un-stabilizes them, per the "Stabilizing a
		// Creature" rules (only a fresh source of damage restarts the dying).
		if ( player.hitPoints <= 0 ) {
			_applyDeathSaveFailure( arguments.state, arguments.opponent, player );
			return;
		}

		var steps = moveToward(
			arguments.opponent, player, int( arguments.opponent.speed / 5 ), grid,
			_otherLivingPositions( arguments.state, arguments.opponent, player )
		);

		if ( steps > 0 ) {
			arguments.state.log.prepend( "#arguments.opponent.name# closes in." );
		}

		if (
			structKeyExists( arguments.opponent, "knownLeveledSpell" ) && !isNull( arguments.opponent.knownLeveledSpell ) &&
			arguments.opponent.knownLeveledSpell.type == "heal" && arguments.opponent.hitPoints <= arguments.opponent.maxHitPoints / 2 &&
			_hasSpellResource( arguments.opponent, 1 )
		) {
			_castLeveledSpellFor( arguments.state, arguments.opponent, player, true );
			return;
		}

		if (
			structKeyExists( arguments.opponent, "knownLeveledSpell" ) && !isNull( arguments.opponent.knownLeveledSpell ) &&
			arguments.opponent.knownLeveledSpell.type == "damage" && _hasSpellResource( arguments.opponent, 1 ) &&
			_isSpellTargetValid( arguments.state, arguments.opponent, player, arguments.opponent.knownLeveledSpell )
		) {
			_castLeveledSpellFor( arguments.state, arguments.opponent, player, true );
			return;
		}
		if (
			structKeyExists( arguments.opponent, "knownCantrip" ) && !isNull( arguments.opponent.knownCantrip ) &&
			_isSpellTargetValid( arguments.state, arguments.opponent, player, arguments.opponent.knownCantrip )
		) {
			_castCantripFor( arguments.state, arguments.opponent, player, true );
			return;
		}

		var choice = pickWeaponForDistance( arguments.opponent, chebyshev( arguments.opponent, player ), grid, player.position );
		if ( isNull( choice ) ) {
			arguments.state.log.prepend( "#arguments.opponent.name# can't reach you this turn." );
			return;
		}

		resolveAttack( arguments.state.log, arguments.opponent, player, choice.weapon, choice.disadvantage, false, false, coverBonus( arguments.state, arguments.opponent, player ) );
		_checkDefenderDefeated( arguments.state, arguments.opponent, player, true );
	}

	/**
	 * Moves `mover` toward `target`, up to `maxSteps`, stopping once adjacent.
	 * Returns steps taken. Without a `grid`, this is the original straight-line
	 * Chebyshev stepper (used by tests, and by any caller with no map). With a
	 * `grid`, it instead follows the shortest wall-avoiding path (via `_bfs()`),
	 * so a mover on the far side of a wall correctly detours through a doorway
	 * rather than walking through the wall.
	 *
	 * @grid Optional level grid (`{width, height, tiles}`, from MapService) to route around walls.
	 * @occupiedPositions Optional array of `{x, y}` — other living combatants' positions (never the mover's own or the target's), treated as impassable alongside walls, so two combatants never end up sharing a tile. Only applies with a `grid`; ignored for the no-grid straight-line stepper (only ever used by callers with no map at all — real gameplay always has one).
	 */
	function moveToward( mover, target, maxSteps, grid = javaCast( "null", 0 ), occupiedPositions = [] ) {
		// Restrained: speed is 0, per the condition's own rules.
		if ( hasCondition( arguments.mover, "Restrained" ) ) {
			return 0;
		}
		if ( isNull( arguments.grid ) ) {
			return _moveTowardUnobstructed( arguments.mover, arguments.target, arguments.maxSteps );
		}

		var targetX = arguments.target.position.x;
		var targetY = arguments.target.position.y;
		var path = _bfs(
			arguments.grid, arguments.mover.position,
			( x, y ) => ( max( abs( x - targetX ), abs( y - targetY ) ) <= 1 ),
			arguments.occupiedPositions
		);
		if ( path.len() <= 1 ) {
			// Already adjacent (path is just the start), or no route exists.
			return 0;
		}

		var steps = min( arguments.maxSteps, path.len() - 1 );
		arguments.mover.position = { "x": path[ steps + 1 ].x, "y": path[ steps + 1 ].y };
		return steps;
	}

	/**
	 * The original obstacle-free mover: steps straight toward `target` one
	 * square at a time (Chebyshev-shortest path assuming an open grid).
	 */
	private function _moveTowardUnobstructed( mover, target, maxSteps ) {
		var distance = chebyshev( arguments.mover, arguments.target );
		var steps = 0;
		while ( distance > 1 && steps < arguments.maxSteps ) {
			var stepX = sgn( arguments.target.position.x - arguments.mover.position.x );
			var stepY = sgn( arguments.target.position.y - arguments.mover.position.y );
			arguments.mover.position = { "x": arguments.mover.position.x + stepX, "y": arguments.mover.position.y + stepY };
			steps += 1;
			distance = chebyshev( arguments.mover, arguments.target );
		}
		return steps;
	}

	/**
	 * Returns `state.grid` if present, or null otherwise — lets
	 * playerDecideAndAct()/runEnemyTurn() pass a grid through to moveToward()
	 * without breaking callers (like the unit tests) whose state has no map.
	 */
	private function _stateGrid( state ) {
		return structKeyExists( arguments.state, "grid" ) ? arguments.state.grid : javaCast( "null", 0 );
	}

	/**
	 * Returns `state.opponents` (the full mob roster) if present, or a
	 * single-element array wrapping `state.opponent` otherwise — lets every
	 * multi-mob-aware function keep working unchanged for callers (like the
	 * unit tests, and any old state shape) that only ever had one opponent.
	 */
	private function _stateOpponents( state ) {
		return structKeyExists( arguments.state, "opponents" ) ? arguments.state.opponents : [ arguments.state.opponent ];
	}

	/**
	 * Positions of every living combatant in `state` except `mover` and
	 * `target` themselves — passed to moveToward() as `occupiedPositions` so
	 * a mover's path never lands on a tile another living combatant already
	 * occupies. `mover`/`target` are excluded by identity (their own current
	 * square is obviously not an obstacle to themselves, and the target's
	 * square is handled separately by moveToward()'s own "adjacent to
	 * target" goal, not by blocking it outright).
	 */
	private function _otherLivingPositions( state, mover, target ) {
		var positions = [];
		var candidates = [ arguments.state.player ];
		for ( var o in _stateOpponents( arguments.state ) ) {
			candidates.append( o );
		}
		for ( var candidate in candidates ) {
			if (
				candidate.hitPoints <= 0 ||
				candidate.name == arguments.mover.name ||
				candidate.name == arguments.target.name
			) {
				continue;
			}
			positions.append( { "x": candidate.position.x, "y": candidate.position.y } );
		}
		return positions;
	}

	/**
	 * True if every opponent in `state.opponents` (or the lone `state.opponent`,
	 * for single-mob state) has been reduced to 0 HP.
	 */
	private function _allOpponentsDefeated( state ) {
		for ( var o in _stateOpponents( arguments.state ) ) {
			if ( o.hitPoints > 0 ) {
				return false;
			}
		}
		return true;
	}

	/**
	 * Picks the closest living opponent to the player (Chebyshev distance) —
	 * used by the auto-battle player AI to decide who to chase/attack. Falls
	 * back to whatever's already in `state.opponent` if every opponent is
	 * somehow already down (shouldn't happen — the encounter should already
	 * be over by then).
	 */
	private function _nearestLivingOpponent( state ) {
		var player = arguments.state.player;
		var nearest = javaCast( "null", 0 );
		var nearestDistance = 0;
		for ( var o in _stateOpponents( arguments.state ) ) {
			if ( o.hitPoints <= 0 ) {
				continue;
			}
			var d = chebyshev( player, o );
			if ( isNull( nearest ) || d < nearestDistance ) {
				nearest = o;
				nearestDistance = d;
			}
		}
		return isNull( nearest ) ? arguments.state.opponent : nearest;
	}

	/**
	 * If `state.opponent` (the player's currently selected target) has been
	 * defeated but others remain, retargets to the next living opponent in
	 * `state.opponents` — so the player isn't stuck "attacking" a corpse.
	 * A no-op for single-mob state or when the current target is still up.
	 */
	private function _retargetIfCurrentOpponentDefeated( state ) {
		if ( !structKeyExists( arguments.state, "opponents" ) || arguments.state.opponent.hitPoints > 0 ) {
			return;
		}
		for ( var o in arguments.state.opponents ) {
			if ( o.hitPoints > 0 ) {
				arguments.state.opponent = o;
				return;
			}
		}
	}

	/**
	 * True if (x, y) is inside `grid` and its tile is "floor" (not "wall").
	 *
	 * @grid A level grid (`{width, height, tiles}`, from MapService).
	 */
	function isWalkable( grid, x, y ) {
		if ( arguments.x < 1 || arguments.x > arguments.grid.width || arguments.y < 1 || arguments.y > arguments.grid.height ) {
			return false;
		}
		return arguments.grid.tiles[ arguments.y ][ arguments.x ] == "floor";
	}

	/**
	 * Shortest wall-avoiding path length (in squares) from `from` to `to`, or
	 * -1 if `to` isn't walkable or no path exists. Used to validate a player's
	 * click-to-move destination against their remaining movement.
	 *
	 * @grid A level grid (`{width, height, tiles}`, from MapService).
	 */
	function pathDistance( grid, from, to ) {
		if ( !isWalkable( arguments.grid, arguments.to.x, arguments.to.y ) ) {
			return -1;
		}
		var toX = arguments.to.x;
		var toY = arguments.to.y;
		var path = _bfs( arguments.grid, arguments.from, ( x, y ) => ( x == toX && y == toY ) );
		return ( path.len() == 0 ) ? -1 : ( path.len() - 1 );
	}

	/**
	 * Finds the closest walkable tile to `origin` that isn't itself in
	 * `excludePositions` — used to place a second, third, etc. mob near the
	 * level's one designed opponent spawn point without stacking them on the
	 * same square or on the player. Returns null if every reachable tile is excluded.
	 *
	 * @grid A level grid (`{width, height, tiles}`, from MapService).
	 * @origin The point to search outward from (typically the level's opponentSpawn).
	 * @excludePositions Array of `{x, y}` points that don't count as open.
	 */
	function findOpenTileNear( grid, origin, excludePositions ) {
		var excluded = arguments.excludePositions;
		var path = _bfs( arguments.grid, arguments.origin, ( x, y ) => {
			for ( var p in excluded ) {
				if ( p.x == x && p.y == y ) {
					return false;
				}
			}
			return true;
		} );
		return ( path.len() == 0 ) ? javaCast( "null", 0 ) : path[ path.len() ];
	}

	/**
