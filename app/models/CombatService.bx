			"#arguments.attacker.name# attacks #arguments.defender.name# with #arguments.weapon.name#: #roll# + #arguments.weapon.attackBonus + styleBonus# = #total# vs AC #effectiveAC##coverNote##disadvantageNote##luckNote##styleNote##inspirationNote#. " &
