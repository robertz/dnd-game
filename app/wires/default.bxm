<bx:output>
<div class="encounter">
	<div class="encounter-main">
		<bx:if gameOver>
			<p class="encounter-banner encounter-banner-#outcome#">
				#( outcome == "victory" ? "Victory! Every enemy is defeated." : "Defeat! " & player.name & " has fallen." )#
			</p>
			<bx:if outcome == "victory" && structKeyExists( player, "pendingAbilityScoreImprovements" ) && player.pendingAbilityScoreImprovements gt 0>
				<bx:set abilityAbbreviations = [ "str", "dex", "con", "int", "wis", "cha" ]>
				<div class="parchment-panel asi-panel">
					<h2 class="fantasy-heading">Ability Score Improvement</h2>
					<p class="encounter-intro">
						#player.name# gains an Ability Score Improvement#( player.pendingAbilityScoreImprovements gt 1 ? " (#player.pendingAbilityScoreImprovements# to choose)" : "" )#. Choose one:
					</p>
					<div class="turn-actions">
						<button type="button" class="btn#( asiMode == "single" ? " btn-auto-battle" : "" )#" wire:click="setAsiMode('single')">+2 to one ability</button>
						<button type="button" class="btn#( asiMode == "double" ? " btn-auto-battle" : "" )#" wire:click="setAsiMode('double')">+1 to two abilities</button>
					</div>
					<div class="creation-scores">
						<label>
							Ability <bx:if asiMode == "double">1</bx:if>:
							<select class="creation-input" wire:model="asiAbility1">
								<bx:loop array="#abilityAbbreviations#" index="abbrev">
									<option value="#abbrev#" #( asiAbility1 == abbrev ? "selected" : "" )#>#uCase( abbrev )# (#player.abilityScores[ abbrev ]#)</option>
								</bx:loop>
							</select>
						</label>
						<bx:if asiMode == "double">
							<label>
								Ability 2:
								<select class="creation-input" wire:model="asiAbility2">
									<bx:loop array="#abilityAbbreviations#" index="abbrev">
										<option value="#abbrev#" #( asiAbility2 == abbrev ? "selected" : "" )#>#uCase( abbrev )# (#player.abilityScores[ abbrev ]#)</option>
									</bx:loop>
								</select>
							</label>
						</bx:if>
					</div>
					<button type="button" class="btn btn-attack" wire:click="confirmAbilityScoreImprovement()">Confirm</button>
				</div>
			</bx:if>
		<bx:else>
			<p class="encounter-intro">Round #round# — #( currentTurn == "player" ? "Your turn." : "Enemy turn…" )#
				<bx:if currentTurn == "player">(#movementRemaining# square(s) of movement left#( actionUsed ? ", action used" : "" )#)</bx:if>
			</p>
		</bx:if>

		<bx:set viewport = viewportBounds()>
		<div class="battle-grid-wrap">
			<div class="battle-grid" style="grid-template-columns: repeat(#viewport.maxCol - viewport.minCol + 1#, 1fr);">
				<bx:loop from="#viewport.minRow#" to="#viewport.maxRow#" index="row">
					<bx:loop from="#viewport.minCol#" to="#viewport.maxCol#" index="col">
						<bx:set isWall = ( grid.tiles[ row ][ col ] == "wall" )>
						<bx:set decoration = grid.decorations[ row ][ col ]>
						<bx:set baseTileClass = len( decoration ) ? ( ' tile-' & decoration ) : ( isWall ? ' tile-wall' : '' )>
						<bx:set isPlayerTile = ( player.position.x == col && player.position.y == row )>
						<bx:set tileOpponent = "">
						<bx:loop array="#opponents#" index="opponentAtTile">
							<bx:if opponentAtTile.hitPoints gt 0 && opponentAtTile.position.x == col && opponentAtTile.position.y == row>
								<bx:set tileOpponent = opponentAtTile>
							</bx:if>
						</bx:loop>
						<bx:set isOpponentTile = !isSimpleValue( tileOpponent )>
						<bx:set isTargetedTile = ( isOpponentTile && tileOpponent.mobIndex == selectedOpponentIndex )>
						<bx:set chebyshev = max( abs( col - player.position.x ), abs( row - player.position.y ) )>
						<bx:set isReachable = ( !isWall && tileReachable( col, row ) )>
						<bx:set isAttackable = ( !gameOver && !autoBattling && currentTurn == "player" && isOpponentTile && !actionUsed && chebyshev <= 1 )>
						<div
							class="tile#baseTileClass##( isPlayerTile ? ' tile-player' : ( isOpponentTile ? ' tile-opponent' : '' ) )##( isTargetedTile ? ' tile-targeted' : '' )##( isReachable ? ' tile-reachable' : '' )##( isAttackable ? ' tile-attackable' : '' )#"
							title="#( isPlayerTile ? player.name : ( isOpponentTile ? tileOpponent.name : ( len( decoration ) ? decoration : ( isWall ? 'Wall' : 'x' & col & ', y' & row ) ) ) )#"
							wire:click="tileClick(#col#, #row#)"
						>#( isPlayerTile ? '⚔' : ( isOpponentTile ? '☠' : '' ) )#</div>
					</bx:loop>
				</bx:loop>
			</div>
		</div>

		<bx:if !gameOver>
			<div class="turn-actions">
				<bx:if autoBattling>
					<div wire:poll.900ms="autoStep()" class="auto-battle-indicator">⚔ Auto-battling…</div>
					<button type="button" class="btn btn-end-turn" wire:click="stopAutoBattle()">Stop</button>
				<bx:else>
					<button type="button" class="btn btn-auto-battle" wire:click="startAutoBattle()">Auto-Battle</button>
					<bx:if currentTurn == "player">
						<bx:if structKeyExists( player, "isDying" ) && player.isDying>
							<button type="button" class="btn btn-attack" wire:click="makeDeathSave()">Make Death Saving Throw</button>
						<bx:elseif player.hitPoints <= 0>
							<p class="encounter-intro">#player.name# is stabilized but unconscious — nothing to do but wait.</p>
							<button type="button" class="btn btn-end-turn" wire:click="endTurn()">End Turn</button>
						<bx:else>
							<bx:set remainingAttacks = attacksRemaining()>
							<bx:if remainingAttacks gt 0 && ( !actionUsed || attacksUsedThisTurn gt 0 )>
								<button type="button" class="btn btn-attack" wire:click="attack()">Attack#( remainingAttacks gt 1 ? " (#remainingAttacks# left)" : "" )#</button>
							</bx:if>
							<bx:if !actionUsed>
								<bx:if structKeyExists( player, "hasGrapplerFeat" ) && player.hasGrapplerFeat>
									<button type="button" class="btn btn-attack" wire:click="attemptGrapple()">Grapple</button>
								</bx:if>
								<button type="button" class="btn btn-attack" wire:click="attemptShove()">Shove</button>
								<bx:if structKeyExists( player, "hasBreathWeapon" ) && player.hasBreathWeapon && !player.usedBreathWeapon>
									<button type="button" class="btn btn-attack" wire:click="useBreathWeapon()">Breath Weapon</button>
								</bx:if>
								<bx:if structKeyExists( player, "knownCantrip" ) && !isNull( player.knownCantrip )>
									<button type="button" class="btn btn-attack" wire:click="castCantrip()">Cast #player.knownCantrip.name#</button>
								</bx:if>
								<bx:if structKeyExists( player, "knownLeveledSpell" ) && !isNull( player.knownLeveledSpell )>
									<button type="button" class="btn btn-attack" wire:click="castLeveledSpell()">Cast #player.knownLeveledSpell.name#</button>
								</bx:if>
							</bx:if>
							<bx:if !bonusActionUsed>
								<button type="button" class="btn btn-attack" wire:click="offHandAttack()">Off-Hand Attack</button>
							</bx:if>
							<button type="button" class="btn btn-end-turn" wire:click="endTurn()">End Turn</button>
						</bx:if>
					</bx:if>
				</bx:if>
			</div>
		</bx:if>
	</div>

	<div class="encounter-sidebar">
		<div class="combatants">
			<bx:set playerBloodied = ( player.hitPoints > 0 && player.hitPoints <= player.maxHitPoints / 2 )>
			<div class="stat-card stat-card-player#( player.hitPoints <= 0 ? ' stat-card-down' : '' )#">
				<h2 class="fantasy-heading">#player.name#</h2>
				<p class="stat-subtitle">Level #player.level# #player.class##( player.hitPoints <= 0 ? " — Unconscious" : ( playerBloodied ? " — Bloodied" : "" ) )#</p>
				<div class="hp-bar"><div class="hp-bar-fill#( playerBloodied ? ' hp-bar-fill-bloodied' : '' )#" style="width:#round( max( player.hitPoints, 0 ) / player.maxHitPoints * 100 )#%;"></div></div>
				<ul class="stat-list">
					<li><strong>AC</strong> #player.armorClass#</li>
					<li><strong>HP</strong> #max( player.hitPoints, 0 )# / #player.maxHitPoints#</li>
					<bx:if structKeyExists( player, "isDying" ) && player.isDying>
						<li><strong>Death Saves</strong> #min( player.deathSaveSuccesses, 3 )# success(es), #min( player.deathSaveFailures, 3 )# failure(s)</li>
					</bx:if>
					<bx:if structKeyExists( player, "conditions" ) && structCount( player.conditions ) gt 0>
						<li><strong>Conditions</strong> #arrayToList( structKeyArray( player.conditions ), ", " )#</li>
					</bx:if>
					<li><strong>Speed</strong> #player.speed# ft.</li>
					<li><strong>Inventory</strong>
						<ul class="inventory-list">
							<bx:loop array="#player.inventory#" index="item">
								<li>#item.name# (+#item.attackBonus# to hit, #item.damageDice#+#item.damageBonus# #item.damageType##( item.category == "ranged" ? ", range " & ( item.normalRange * 5 ) & "/" & ( item.longRange * 5 ) & " ft." : "" )#)</li>
							</bx:loop>
						</ul>
					</li>
					<li><strong>Saving Throws</strong> #arrayToList( player.savingThrowProficiencies, ", " )#</li>
					<li><strong>Features</strong> #arrayToList( player.features, ", " )#</li>
					<bx:if structKeyExists( player, "isSpellcaster" ) && player.isSpellcaster>
						<li><strong>Spell Slots</strong>
							<bx:if structCount( player.spellSlots ) == 0>
								none
							<bx:else>
								<bx:loop collection="#player.spellSlots#" item="spellLevel">
									L#spellLevel#: #player.spellSlots[ spellLevel ]#&nbsp;
								</bx:loop>
							</bx:if>
						</li>
					</bx:if>
				</ul>
			</div>

			<bx:loop array="#opponents#" index="foe">
				<bx:set foeBloodied = ( foe.hitPoints > 0 && foe.hitPoints <= foe.maxHitPoints / 2 )>
				<bx:set foeTargeted = ( foe.mobIndex == selectedOpponentIndex )>
				<div
					class="stat-card stat-card-opponent#( foe.hitPoints <= 0 ? ' stat-card-down' : '' )##( foeTargeted && foe.hitPoints gt 0 ? ' stat-card-targeted' : '' )#"
					wire:click="selectTarget(#foe.mobIndex#)"
				>
					<h2 class="fantasy-heading">#foe.name##( foeTargeted && foe.hitPoints gt 0 ? ' 🎯' : '' )#</h2>
					<p class="stat-subtitle">Medium #foe.creatureType##( foe.hitPoints <= 0 ? " — Destroyed" : ( foeBloodied ? " — Bloodied" : "" ) )#</p>
					<div class="hp-bar"><div class="hp-bar-fill#( foeBloodied ? ' hp-bar-fill-bloodied' : '' )#" style="width:#round( max( foe.hitPoints, 0 ) / foe.maxHitPoints * 100 )#%;"></div></div>
					<ul class="stat-list">
						<li><strong>AC</strong> #foe.armorClass#</li>
						<li><strong>HP</strong> #max( foe.hitPoints, 0 )# / #foe.maxHitPoints#</li>
						<bx:if structKeyExists( foe, "conditions" ) && structCount( foe.conditions ) gt 0>
							<li><strong>Conditions</strong> #arrayToList( structKeyArray( foe.conditions ), ", " )#</li>
						</bx:if>
						<li><strong>Speed</strong> #foe.speed# ft.</li>
						<li><strong>Inventory</strong>
							<ul class="inventory-list">
								<bx:loop array="#foe.inventory#" index="item">
									<li>#item.name# (+#item.attackBonus# to hit, #item.damageDice#+#item.damageBonus# #item.damageType##( item.category == "ranged" ? ", range " & ( item.normalRange * 5 ) & "/" & ( item.longRange * 5 ) & " ft." : "" )#)</li>
								</bx:loop>
							</ul>
						</li>
						<li><strong>Vulnerable</strong> #arrayToList( foe.vulnerabilities, ", " )#</li>
						<li><strong>Immune</strong> #arrayToList( foe.immunities, ", " )#</li>
					</ul>
				</div>
			</bx:loop>
		</div>

		<div class="combat-log">
			<h2 class="fantasy-heading">Combat Log</h2>
			<ul class="log-list">
				<bx:loop array="#log#" index="entry">
					<li>#entry#</li>
				</bx:loop>
			</ul>
		</div>
	</div>
</div>
</bx:output>
