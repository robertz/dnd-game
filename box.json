{
    "name":"dnd-game",
    "version":"1.0.0",
    "author":"You",
    "location":"forgeboxStorage",
    "slug":"dnd-game",
    "createPackageDirectory":false,
    "type":"mvc",
    "language":"boxlang",
    "keywords":"boxlang",
    "shortDescription":"The default starter template for a ColdBox application using BoxLang",
    "ignore":[],
    "dependencies":{
        "coldbox":"^8.0.0",
        "cbwire":"^5.0.4",
        "cbstorages":"^3.5.0+5",
        "qb":"^13.1.0"
    },
    "devDependencies":{
        "testbox":"*",
        "route-visualizer":"*",
        "commandbox-boxlang":"*"
    },
    "installPathConventions":{
        "modules":"lib/modules"
    },
    "installPaths":{
        "coldbox":"lib/coldbox/",
        "testbox":"lib/testbox/",
        "route-visualizer":"lib/modules/route-visualizer/",
        "cbwire":"lib/modules/cbwire/",
        "cbstorages":"lib/modules/cbstorages/",
        "qb":"lib/modules/qb/"
    },
    "scripts":{
        "format":"!boxlang format --source app/,tests/specs/,*.bx",
        "format:check":"!boxlang format --check --source app/,tests/specs/,*.bx",
        "docker:build":"!docker build --no-cache -t my-coldbox-app -f ./docker/Dockerfile ./",
        "docker:run":"!docker run -it -p 8080:8080 my-coldbox-app",
        "docker:bash":"!docker run -it my-coldbox-app /bin/bash",
        "docker:stack":"!docker compose -f docker/docker-compose.yaml ${1}"
    },
    "testbox":{
        "runner":"/tests/runner.bxm"
    },
    "description":"A ColdBox Application created with the ColdBox CLI"
}
