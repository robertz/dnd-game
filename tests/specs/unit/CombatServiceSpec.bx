/**
 * Unit tests for app/models/CombatService.bx — the grid combat rules engine.
 *
 * This is instantiated directly (no ColdBox app bootstrap, no WireBox), since
 * CombatService has no injected dependencies of its own. Attack rolls are real
 * dice (no mocked RNG), so tests that depend on a roll either use overwhelming
 * bonuses/penalties to make the outcome effectively certain, account for both
 * possible outcomes explicitly, or assert on an aggregate across many trials —
 * see inline notes. Tests intentionally avoid ever reducing a defender's HP to
 * 0, since a kill triggers a real UPDATE against the `characters` table via
 * awardExperience(); covering that write path belongs in an integration-style
 * test with its own DB fixture, not here.
 */
class extends="testbox.system.BaseSpec" {

	function beforeAll(){
		variables.service = new app.models.CombatService();
	}

	private function makeCombatant( x, y, extra = {} ){
		var base = {
			"name": "Combatant",
			"position": { "x": arguments.x, "y": arguments.y },
			"speed": 30,
			"armorClass": 10,
			"hitPoints": 500,
			"maxHitPoints": 500,
			"inventory": []
		};
		base.append( arguments.extra );
		return base;
	}

	/**
	 * A 5x5 test grid. If `wallRow` is between 1-5, that entire row is a wall
	 * except for a single-tile gap at `gapCol` (or no gap at all, fully
	 * sealing the grid in two halves, if `gapCol` is out of range). If
	 * `wallRow` is out of range, the grid is entirely open floor.
	 */
	private function makeWallGrid( wallRow, gapCol ){
		var width = 5;
		var height = 5;
		var tiles = [];
		for ( var y = 1; y <= height; y++ ) {
			var row = [];
			for ( var x = 1; x <= width; x++ ) {
				var isWall = ( y == arguments.wallRow && x != arguments.gapCol );
				arrayAppend( row, isWall ? "wall" : "floor" );
			}
			arrayAppend( tiles, row );
		}
		return { "width": width, "height": height, "tiles": tiles };
	}

	function run(){
		describe( "CombatService", () => {

			describe( "chebyshev()", () => {
				it( "is 0 for the same position", () => {
					var a = makeCombatant( 5, 5 );
					expect( service.chebyshev( a, a ) ).toBe( 0 );
				} );

				it( "is the straight-line distance along one axis", () => {
					var a = makeCombatant( 0, 0 );
					var b = makeCombatant( 0, 7 );
					expect( service.chebyshev( a, b ) ).toBe( 7 );
				} );

				it( "uses the larger axis for diagonals, not Euclidean distance", () => {
					var a = makeCombatant( 0, 0 );
					var b = makeCombatant( 3, 4 );
					expect( service.chebyshev( a, b ) ).toBe( 4 );
				} );
			} );

			describe( "moveToward()", () => {
				it( "does not move if already adjacent", () => {
					var mover = makeCombatant( 5, 5 );
					var target = makeCombatant( 6, 5 );
					var steps = service.moveToward( mover, target, 6 );
					expect( steps ).toBe( 0 );
					expect( mover.position.x ).toBe( 5 );
				} );

				it( "steps toward the target up to the step budget", () => {
					var mover = makeCombatant( 0, 0 );
					var target = makeCombatant( 10, 0 );
					var steps = service.moveToward( mover, target, 4 );
					expect( steps ).toBe( 4 );
					expect( mover.position.x ).toBe( 4 );
				} );

				it( "stops once adjacent, even with movement budget left", () => {
					var mover = makeCombatant( 0, 0 );
					var target = makeCombatant( 3, 0 );
					var steps = service.moveToward( mover, target, 6 );
					expect( steps ).toBe( 2 );
					expect( service.chebyshev( mover, target ) ).toBe( 1 );
				} );

				it( "moves diagonally when both axes differ", () => {
					var mover = makeCombatant( 0, 0 );
					var target = makeCombatant( 10, 10 );
					var steps = service.moveToward( mover, target, 6 );
					expect( steps ).toBe( 6 );
					expect( mover.position.x ).toBe( 6 );
					expect( mover.position.y ).toBe( 6 );
				} );

				it( "with a grid, routes around a wall instead of walking through it", () => {
					// 5x5 grid: row 3 (1-based) is a solid wall except a gap at
					// column 1. Mover and target sit on opposite sides, off the
					// gap's column, so a direct line would cross the wall.
					var grid = makeWallGrid( 3, 1 );
					var mover = makeCombatant( 5, 1 );
					var target = makeCombatant( 5, 5 );
					var steps = service.moveToward( mover, target, 100, grid );
					expect( service.isWalkable( grid, mover.position.x, mover.position.y ) ).toBeTrue();
					// A direct line is 4 squares (Chebyshev); detouring to the
					// column-1 gap and back costs strictly more.
					expect( steps ).toBeGT( 4 );
				} );

				it( "with a grid, doesn't move if the target is unreachable", () => {
					var grid = makeWallGrid( 3, -1 ); // no gap at all — fully sealed
					var mover = makeCombatant( 5, 1 );
					var target = makeCombatant( 5, 5 );
					var steps = service.moveToward( mover, target, 100, grid );
					expect( steps ).toBe( 0 );
					expect( mover.position.x ).toBe( 5 );
					expect( mover.position.y ).toBe( 1 );
				} );

				it( "with a grid, never ends on a tile occupied by another living combatant", () => {
					// makeWallGrid() is always 5x5, so a target at the center
					// (3,3) has a full ring of 8 in-bounds neighbors — block 7
					// of them, leaving exactly one (3,4) free to route to.
					var grid = makeWallGrid( -1, -1 ); // fully open
					var mover = makeCombatant( 1, 1 );
					var target = makeCombatant( 3, 3 );
					var occupied = [
						{ "x": 2, "y": 2 }, { "x": 3, "y": 2 }, { "x": 4, "y": 2 },
						{ "x": 2, "y": 3 }, { "x": 4, "y": 3 },
						{ "x": 2, "y": 4 }, { "x": 4, "y": 4 }
					];
					var steps = service.moveToward( mover, target, 100, grid, occupied );
					expect( steps ).toBeGT( 0 );
					for ( var blockedPos in occupied ) {
						expect( mover.position.x == blockedPos.x && mover.position.y == blockedPos.y ).toBeFalse();
					}
					expect( mover.position.x ).toBe( 3 );
					expect( mover.position.y ).toBe( 4 );
				} );

				it( "with a grid, detours around an occupied tile blocking the direct path", () => {
					var grid = makeWallGrid( -1, -1 ); // fully open
					var mover = makeCombatant( 1, 1 );
					var target = makeCombatant( 5, 1 );
					// Blocks the straight-line row between mover and target —
					// with enough budget, the mover should still reach
					// adjacency by detouring through row 2, rather than
					// treating the occupied row as impassable and getting stuck.
					var occupied = [ { "x": 2, "y": 1 }, { "x": 3, "y": 1 }, { "x": 4, "y": 1 } ];
					var steps = service.moveToward( mover, target, 10, grid, occupied );
					for ( var blockedPos in occupied ) {
						expect( mover.position.x == blockedPos.x && mover.position.y == blockedPos.y ).toBeFalse();
					}
					expect( service.chebyshev( mover, target ) ).toBe( 1 );
				} );
			} );

			describe( "isWalkable()", () => {
				it( "is true for a floor tile and false for a wall tile", () => {
					var grid = makeWallGrid( 3, 1 );
					expect( service.isWalkable( grid, 1, 3 ) ).toBeTrue(); // the gap
					expect( service.isWalkable( grid, 4, 3 ) ).toBeFalse(); // the wall
				} );

				it( "is false outside the grid's bounds", () => {
					var grid = makeWallGrid( 3, 1 );
					expect( service.isWalkable( grid, 0, 1 ) ).toBeFalse();
					expect( service.isWalkable( grid, 6, 1 ) ).toBeFalse();
					expect( service.isWalkable( grid, 1, 0 ) ).toBeFalse();
					expect( service.isWalkable( grid, 1, 6 ) ).toBeFalse();
				} );
			} );

			describe( "pathDistance()", () => {
				it( "matches Chebyshev distance on an open grid", () => {
					var grid = makeWallGrid( -1, -1 ); // no wall row at all
					expect( service.pathDistance( grid, { "x": 1, "y": 1 }, { "x": 4, "y": 3 } ) ).toBe( 3 );
				} );

				it( "is longer than the raw Chebyshev distance when a wall forces a detour", () => {
					var grid = makeWallGrid( 3, 1 );
					var rawChebyshev = 4;
					var distance = service.pathDistance( grid, { "x": 5, "y": 1 }, { "x": 5, "y": 5 } );
					expect( distance ).toBeGT( rawChebyshev );
				} );

				it( "returns -1 when the destination is walled off entirely", () => {
					var grid = makeWallGrid( 3, -1 ); // no gap — fully sealed
					expect( service.pathDistance( grid, { "x": 5, "y": 1 }, { "x": 5, "y": 5 } ) ).toBe( -1 );
				} );

				it( "returns -1 when the destination tile is itself a wall", () => {
					var grid = makeWallGrid( 3, 1 );
					expect( service.pathDistance( grid, { "x": 1, "y": 1 }, { "x": 4, "y": 3 } ) ).toBe( -1 );
				} );
			} );

			describe( "equippedWeapon()", () => {
				it( "returns the equipped weapon of the requested category", () => {
					var combatant = makeCombatant( 0, 0, { "inventory": [
						{ "category": "melee", "equipped": true, "name": "Greatsword" },
						{ "category": "ranged", "equipped": true, "name": "Javelin" }
					] } );
					expect( service.equippedWeapon( combatant, "ranged" ).name ).toBe( "Javelin" );
				} );

				it( "ignores unequipped items", () => {
					var combatant = makeCombatant( 0, 0, { "inventory": [
						{ "category": "melee", "equipped": false, "name": "Dagger" }
					] } );
					expect( isNull( service.equippedWeapon( combatant, "melee" ) ) ).toBeTrue();
				} );

				it( "returns null when nothing of that category is carried", () => {
					var combatant = makeCombatant( 0, 0 );
					expect( isNull( service.equippedWeapon( combatant, "ranged" ) ) ).toBeTrue();
				} );
			} );

			describe( "pickWeaponForDistance()", () => {
				function fighterWithBothWeapons(){
					return makeCombatant( 0, 0, { "inventory": [
						{ "category": "melee", "equipped": true, "name": "Greatsword" },
						{ "category": "ranged", "equipped": true, "name": "Javelin", "normalRange": 6, "longRange": 24 }
					] } );
				}

				it( "prefers melee when adjacent", () => {
					var choice = service.pickWeaponForDistance( fighterWithBothWeapons(), 1 );
					expect( choice.weapon.name ).toBe( "Greatsword" );
					expect( choice.disadvantage ).toBeFalse();
				} );

				it( "falls back to the ranged weapon within normal range, no Disadvantage", () => {
					var choice = service.pickWeaponForDistance( fighterWithBothWeapons(), 4 );
					expect( choice.weapon.name ).toBe( "Javelin" );
					expect( choice.disadvantage ).toBeFalse();
				} );

				it( "applies Disadvantage beyond normal range but within long range", () => {
					var choice = service.pickWeaponForDistance( fighterWithBothWeapons(), 10 );
					expect( choice.weapon.name ).toBe( "Javelin" );
					expect( choice.disadvantage ).toBeTrue();
				} );

				it( "returns null when the target is beyond long range", () => {
					var combatant = makeCombatant( 0, 0, { "inventory": [
						{ "category": "ranged", "equipped": true, "name": "Javelin", "normalRange": 6, "longRange": 24 }
					] } );
					expect( isNull( service.pickWeaponForDistance( combatant, 25 ) ) ).toBeTrue();
				} );

				it( "returns null when no weapon is carried at all", () => {
					expect( isNull( service.pickWeaponForDistance( makeCombatant( 0, 0 ), 1 ) ) ).toBeTrue();
				} );

				it( "returns null for a ranged shot blocked by a wall, even within range", () => {
					// Wall spans row 3 with no gap, so a shot straight across it is blocked.
					var grid = makeWallGrid( 3, -1 );
					var archer = makeCombatant( 3, 1, { "inventory": [
						{ "category": "ranged", "equipped": true, "name": "Shortbow", "normalRange": 16, "longRange": 64 }
					] } );
					var choice = service.pickWeaponForDistance( archer, 4, grid, { "x": 3, "y": 5 } );
					expect( isNull( choice ) ).toBeTrue();
				} );

				it( "still offers the ranged shot when the line of sight is clear", () => {
					var grid = makeWallGrid( 3, 1 ); // gap at column 1
					var archer = makeCombatant( 1, 1, { "inventory": [
						{ "category": "ranged", "equipped": true, "name": "Shortbow", "normalRange": 16, "longRange": 64 }
					] } );
					// Straight down column 1, through the gap — nothing in the way.
					var choice = service.pickWeaponForDistance( archer, 4, grid, { "x": 1, "y": 5 } );
					expect( isNull( choice ) ).toBeFalse();
					expect( choice.weapon.name ).toBe( "Shortbow" );
				} );
			} );

			describe( "hasLineOfSight()", () => {
				it( "is true across an open grid", () => {
					var grid = makeWallGrid( -1, -1 );
					expect( service.hasLineOfSight( grid, { "x": 1, "y": 1 }, { "x": 5, "y": 5 } ) ).toBeTrue();
				} );

				it( "is false when a wall lies on the straight line between two points", () => {
					var grid = makeWallGrid( 3, -1 ); // solid wall all the way across row 3
					expect( service.hasLineOfSight( grid, { "x": 3, "y": 1 }, { "x": 3, "y": 5 } ) ).toBeFalse();
				} );

				it( "is true when the line threads through a gap in the wall", () => {
					var grid = makeWallGrid( 3, 1 ); // gap at column 1
					expect( service.hasLineOfSight( grid, { "x": 1, "y": 1 }, { "x": 1, "y": 5 } ) ).toBeTrue();
				} );

				it( "doesn't check the endpoints themselves, only tiles in between", () => {
					// Target sits one tile short of (and adjacent to) a solid wall
					// row — the line from directly above it never crosses any
					// wall tile in between, so sight is clear right up to it.
					var grid = makeWallGrid( 3, -1 );
					expect( service.hasLineOfSight( grid, { "x": 3, "y": 1 }, { "x": 3, "y": 2 } ) ).toBeTrue();
				} );
			} );

			describe( "coverBonus()", () => {
				it( "returns 0 without a grid", () => {
					var attacker = makeCombatant( 1, 1 );
					var defender = makeCombatant( 5, 1 );
					var state = { "player": attacker, "opponents": [ defender ] };
					expect( service.coverBonus( state, attacker, defender ) ).toBe( 0 );
				} );

				it( "returns 0 when attacker and defender are adjacent — nothing can stand between them", () => {
					var grid = makeWallGrid( -1, -1 );
					var attacker = makeCombatant( 1, 1 );
					var defender = makeCombatant( 2, 1 );
					var state = { "grid": grid, "player": attacker, "opponents": [ defender ] };
					expect( service.coverBonus( state, attacker, defender ) ).toBe( 0 );
				} );

				it( "returns 0 with a clear line between attacker and defender", () => {
					var grid = makeWallGrid( -1, -1 );
					var attacker = makeCombatant( 1, 1 );
					var defender = makeCombatant( 5, 1 );
					var state = { "grid": grid, "player": attacker, "opponents": [ defender ] };
					expect( service.coverBonus( state, attacker, defender ) ).toBe( 0 );
				} );

				it( "returns 2 (Half Cover) when another living combatant stands on the line between them", () => {
					var grid = makeWallGrid( -1, -1 );
					var attacker = makeCombatant( 1, 1 );
					var defender = makeCombatant( 5, 1 );
					var blocker = makeCombatant( 3, 1, { "name": "Blocker" } );
					var state = { "grid": grid, "player": attacker, "opponents": [ defender, blocker ] };
					expect( service.coverBonus( state, attacker, defender ) ).toBe( 2 );
				} );

				it( "ignores a downed combatant standing on the line", () => {
					var grid = makeWallGrid( -1, -1 );
					var attacker = makeCombatant( 1, 1 );
					var defender = makeCombatant( 5, 1 );
					var downedBlocker = makeCombatant( 3, 1, { "name": "Blocker", "hitPoints": 0 } );
					var state = { "grid": grid, "player": attacker, "opponents": [ defender, downedBlocker ] };
					expect( service.coverBonus( state, attacker, defender ) ).toBe( 0 );
				} );
			} );

			describe( "parseDice()", () => {
				it( "parses NdM notation into count and sides", () => {
					var dice = service.parseDice( "2d6" );
					expect( dice.count ).toBe( 2 );
					expect( dice.sides ).toBe( 6 );
				} );

				it( "handles a single die", () => {
					var dice = service.parseDice( "1d4" );
					expect( dice.count ).toBe( 1 );
					expect( dice.sides ).toBe( 4 );
				} );
			} );

			describe( "rollSum()", () => {
				it( "stays within the mathematically possible range across many rolls", () => {
					for ( var i = 1; i <= 100; i++ ) {
						var total = service.rollSum( 2, 6 );
						expect( total ).toBeGTE( 2 );
						expect( total ).toBeLTE( 12 );
					}
				} );
			} );

			describe( "resolveAttack()", () => {
				it( "deals damage within the weapon's dice range on an overwhelming hit", () => {
					// attackBonus 100 vs AC 1: only a natural 1 (auto-miss, per the rules) can
					// prevent a hit, so across many trials the outcome is either "missed" (0
					// damage), a normal hit (2d6+2 -> 4-14), or a Critical Hit, which doubles
					// the damage dice (4d6+2 -> 6-26).
					for ( var i = 1; i <= 40; i++ ) {
						var log = [];
						var attacker = { "name": "Attacker" };
						var defender = makeCombatant( 0, 0, { "armorClass": 1 } );
						var weapon = { "name": "Greatsword", "damageDice": "2d6", "damageType": "Slashing", "attackBonus": 100, "damageBonus": 2 };
						service.resolveAttack( log, attacker, defender, weapon, false );
						var damageTaken = 500 - defender.hitPoints;
						expect( damageTaken == 0 || ( damageTaken >= 4 && damageTaken <= 26 ) ).toBeTrue();
						expect( log.len() ).toBe( 1 );
					}
				} );

				it( "mostly misses on an overwhelming penalty, barring a natural 20", () => {
					var misses = 0;
					var trials = 100;
					for ( var i = 1; i <= trials; i++ ) {
						var log = [];
						var attacker = { "name": "Attacker" };
						var defender = makeCombatant( 0, 0, { "armorClass": 999 } );
						var weapon = { "name": "Dagger", "damageDice": "1d4", "damageType": "Piercing", "attackBonus": -50, "damageBonus": 0 };
						service.resolveAttack( log, attacker, defender, weapon, false );
						if ( defender.hitPoints == 500 ) {
							misses += 1;
						}
					}
					// Only a natural 20 (1-in-20) can hit here, so misses should dominate.
					expect( misses ).toBeGTE( trials * 0.8 );
				} );

				it( "zeroes damage against an immune damage type", () => {
					var log = [];
					var attacker = { "name": "Attacker" };
					var defender = makeCombatant( 0, 0, { "armorClass": 1, "immunities": [ "Poison" ] } );
					var weapon = { "name": "Poison Dart", "damageDice": "2d6", "damageType": "Poison", "attackBonus": 100, "damageBonus": 5 };
					service.resolveAttack( log, attacker, defender, weapon, false );
					// Immune on a hit, and untouched on a (rare) fumble — either way, no damage.
					expect( defender.hitPoints ).toBe( 500 );
				} );

				it( "doubles damage against a vulnerable damage type", () => {
					// A 1-sided die always rolls 1, so a normal hit deals exactly 1 damage;
					// Vulnerability doubles that to 2. A fumble (no hit at all) leaves HP untouched.
					var log = [];
					var attacker = { "name": "Attacker" };
					var defender = makeCombatant( 0, 0, { "armorClass": 1, "vulnerabilities": [ "Bludgeoning" ] } );
					var weapon = { "name": "Club", "damageDice": "1d1", "damageType": "Bludgeoning", "attackBonus": 100, "damageBonus": 0 };
					service.resolveAttack( log, attacker, defender, weapon, false );
					expect( defender.hitPoints == 500 || defender.hitPoints == 498 ).toBeTrue();
				} );

				it( "rolls damage dice twice on a natural 20 (Critical Hit)", () => {
					// A 1-sided die always rolls 1: normal hit = 1+0 = 1 damage, critical = 2+0 = 2 damage.
					// Force the crit deterministically isn't possible without mocking, so run enough
					// trials that at least one natural 20 (1-in-20) is virtually guaranteed to appear,
					// and confirm at least one trial took exactly the critical amount.
					var sawCritDamage = false;
					for ( var i = 1; i <= 200; i++ ) {
						var log = [];
						var attacker = { "name": "Attacker" };
						var defender = makeCombatant( 0, 0, { "armorClass": 1 } );
						var weapon = { "name": "Club", "damageDice": "1d1", "damageType": "Bludgeoning", "attackBonus": 0, "damageBonus": 0 };
						service.resolveAttack( log, attacker, defender, weapon, false );
						if ( ( 500 - defender.hitPoints ) == 2 ) {
							sawCritDamage = true;
							break;
						}
					}
					expect( sawCritDamage ).toBeTrue();
				} );
			} );

			describe( "conditions", () => {
				it( "hasCondition()/addCondition()/removeCondition() track condition state", () => {
					var combatant = makeCombatant( 0, 0 );
					expect( service.hasCondition( combatant, "Prone" ) ).toBeFalse();
					service.addCondition( combatant, "Prone" );
					expect( service.hasCondition( combatant, "Prone" ) ).toBeTrue();
					service.removeCondition( combatant, "Prone" );
					expect( service.hasCondition( combatant, "Prone" ) ).toBeFalse();
				} );

				it( "gives melee Advantage, but ranged Disadvantage, against a Prone target", () => {
					var defender = makeCombatant( 0, 0, { "armorClass": 10 } );
					service.addCondition( defender, "Prone" );

					var meleeLog = [];
					service.resolveAttack( meleeLog, { "name": "Attacker" }, defender, { "name": "Sword", "category": "melee", "damageDice": "1d6", "damageType": "Slashing", "attackBonus": 0, "damageBonus": 0 }, false );
					expect( meleeLog[ 1 ] ).toInclude( "(Advantage)" );

					var rangedLog = [];
					service.resolveAttack( rangedLog, { "name": "Attacker" }, defender, { "name": "Bow", "category": "ranged", "damageDice": "1d6", "damageType": "Piercing", "attackBonus": 0, "damageBonus": 0 }, false );
					expect( rangedLog[ 1 ] ).toInclude( "(Disadvantage)" );
				} );

				it( "gives Advantage to attacks against a Restrained target, and Disadvantage to the Restrained combatant's own attacks", () => {
					var defender = makeCombatant( 0, 0, { "armorClass": 10 } );
					service.addCondition( defender, "Restrained" );
					var log = [];
					service.resolveAttack( log, { "name": "Attacker" }, defender, { "name": "Sword", "category": "melee", "damageDice": "1d6", "damageType": "Slashing", "attackBonus": 0, "damageBonus": 0 }, false );
					expect( log[ 1 ] ).toInclude( "(Advantage)" );

					var restrainedAttacker = makeCombatant( 0, 0 );
					service.addCondition( restrainedAttacker, "Restrained" );
					var log2 = [];
					service.resolveAttack( log2, restrainedAttacker, makeCombatant( 0, 0, { "armorClass": 10 } ), { "name": "Sword", "category": "melee", "damageDice": "1d6", "damageType": "Slashing", "attackBonus": 0, "damageBonus": 0 }, false );
					expect( log2[ 1 ] ).toInclude( "(Disadvantage)" );
				} );

				it( "Poisoned and Frightened both give Disadvantage on the combatant's own attacks", () => {
					for ( var condition in [ "Poisoned", "Frightened" ] ) {
						var attacker = makeCombatant( 0, 0 );
						service.addCondition( attacker, condition );
						var log = [];
						service.resolveAttack( log, attacker, makeCombatant( 0, 0, { "armorClass": 10 } ), { "name": "Sword", "category": "melee", "damageDice": "1d6", "damageType": "Slashing", "attackBonus": 0, "damageBonus": 0 }, false );
						expect( log[ 1 ] ).toInclude( "(Disadvantage)" );
					}
				} );

				it( "Advantage and Disadvantage from conditions cancel out, same as explicit flags", () => {
					var defender = makeCombatant( 0, 0, { "armorClass": 10 } );
					service.addCondition( defender, "Restrained" ); // would grant the attacker Advantage
					var attacker = makeCombatant( 0, 0 );
					service.addCondition( attacker, "Poisoned" ); // would give the attacker Disadvantage
					var log = [];
					service.resolveAttack( log, attacker, defender, { "name": "Sword", "category": "melee", "damageDice": "1d6", "damageType": "Slashing", "attackBonus": 0, "damageBonus": 0 }, false );
					expect( log[ 1 ] ).notToInclude( "(Advantage)" );
					expect( log[ 1 ] ).notToInclude( "(Disadvantage)" );
				} );

				it( "rollSavingThrow() gives Disadvantage on Dexterity saves while Restrained", () => {
					var combatant = makeCombatant( 0, 0, { "modifiers": { "dex": 0, "str": 0 }, "proficiencyBonus": 0 } );
					service.addCondition( combatant, "Restrained" );
					var result = service.rollSavingThrow( combatant, "dex", 10 );
					expect( result.hadDisadvantage ).toBeTrue();

					// Doesn't affect saves against other abilities.
					var strResult = service.rollSavingThrow( combatant, "str", 10 );
					expect( strResult.hadDisadvantage ).toBeFalse();
				} );

				it( "moveToward() returns 0 steps for a Restrained mover — Restrained speed is 0", () => {
					var mover = makeCombatant( 1, 1 );
					service.addCondition( mover, "Restrained" );
					var target = makeCombatant( 10, 1 );
					var steps = service.moveToward( mover, target, 6 );
					expect( steps ).toBe( 0 );
					expect( mover.position.x ).toBe( 1 );
				} );

				it( "attemptGrapple() applies the Restrained condition on success", () => {
					var attacker = makeCombatant( 1, 1, { "modifiers": { "str": 10 }, "proficiencyBonus": 10 } );
					var defender = makeCombatant( 2, 1, { "modifiers": { "str": -10, "dex": -10 } } );
					var state = { "log": [], "actionUsed": false };
					service.attemptGrapple( state, attacker, defender );
					expect( defender.grappledBy ).toBe( attacker.name );
					expect( service.hasCondition( defender, "Restrained" ) ).toBeTrue();
				} );

				it( "attemptShove() applies the Prone condition on success", () => {
					var attacker = makeCombatant( 1, 1, { "modifiers": { "str": 10 }, "proficiencyBonus": 10 } );
					var defender = makeCombatant( 2, 1, { "modifiers": { "str": -10, "dex": -10 } } );
					var state = { "log": [], "actionUsed": false };
					service.attemptShove( state, attacker, defender );
					expect( service.hasCondition( defender, "Prone" ) ).toBeTrue();
				} );
			} );

			describe( "Magic Resistance (rollSavingThrow())", () => {
				it( "grants Advantage on a save against a magical effect", () => {
					var combatant = makeCombatant( 0, 0, { "modifiers": { "wis": 0 }, "proficiencyBonus": 0, "hasMagicResistance": true } );
					var result = service.rollSavingThrow( combatant, "wis", 10, "", true );
					expect( result.hadAdvantage ).toBeTrue();
				} );

				it( "does not apply to a non-magical save", () => {
					var combatant = makeCombatant( 0, 0, { "modifiers": { "wis": 0 }, "proficiencyBonus": 0, "hasMagicResistance": true } );
					var result = service.rollSavingThrow( combatant, "wis", 10, "", false );
					expect( result.hadAdvantage ).toBeFalse();
				} );

				it( "does not apply without the trait", () => {
					var combatant = makeCombatant( 0, 0, { "modifiers": { "wis": 0 }, "proficiencyBonus": 0 } );
					var result = service.rollSavingThrow( combatant, "wis", 10, "", true );
					expect( result.hadAdvantage ).toBeFalse();
				} );
			} );

			describe( "Parry reaction (resolveAttack())", () => {
				// AC 15 + parryBonus 5 vs attackBonus 0: rolls 15-19 land as a normal
				// hit (roll >= 15) that adding the parry bonus (up to 20) always
				// downgrades to a miss — deterministic for any non-crit, non-fumble
				// hit in this band, unlike the file's usual "run trials, assert an
				// aggregate" pattern.
				it( "turns a would-be hit into a miss and spends the Reaction", () => {
					var sawParry = false;
					for ( var i = 1; i <= 300 && !sawParry; i++ ) {
						var log = [];
						var defender = makeCombatant( 0, 0, { "armorClass": 15, "parryBonus": 5 } );
						var weapon = { "name": "Longsword", "category": "melee", "damageDice": "1d8", "damageType": "Slashing", "attackBonus": 0, "damageBonus": 0 };
						service.resolveAttack( log, { "name": "Attacker" }, defender, weapon, false );
						if ( log[ 1 ] contains "Parried" ) {
							sawParry = true;
							expect( defender.hitPoints ).toBe( 500 );
							expect( defender.reactionUsed ).toBeTrue();
						}
					}
					expect( sawParry ).toBeTrue();
				} );

				it( "cannot prevent a natural 20 (Critical Hit)", () => {
					var sawCrit = false;
					for ( var i = 1; i <= 400 && !sawCrit; i++ ) {
						var log = [];
						var defender = makeCombatant( 0, 0, { "armorClass": 15, "parryBonus": 5 } );
						var weapon = { "name": "Longsword", "category": "melee", "damageDice": "1d8", "damageType": "Slashing", "attackBonus": 0, "damageBonus": 0 };
						service.resolveAttack( log, { "name": "Attacker" }, defender, weapon, false );
						if ( log[ 1 ] contains "Critical hit!" ) {
							sawCrit = true;
							expect( defender.hitPoints ).toBeLT( 500 );
						}
					}
					expect( sawCrit ).toBeTrue();
				} );

				it( "does not apply once the Reaction is already used this round", () => {
					var sawRealHit = false;
					for ( var i = 1; i <= 300; i++ ) {
						var log = [];
						var defender = makeCombatant( 0, 0, { "armorClass": 15, "parryBonus": 5, "reactionUsed": true } );
						var weapon = { "name": "Longsword", "category": "melee", "damageDice": "1d8", "damageType": "Slashing", "attackBonus": 0, "damageBonus": 0 };
						service.resolveAttack( log, { "name": "Attacker" }, defender, weapon, false );
						expect( log[ 1 ] ).notToInclude( "Parried" );
						if ( defender.hitPoints < 500 ) {
							sawRealHit = true;
						}
					}
					expect( sawRealHit ).toBeTrue();
				} );

				it( "does not apply to ranged attacks", () => {
					for ( var i = 1; i <= 40; i++ ) {
						var log = [];
						var defender = makeCombatant( 0, 0, { "armorClass": 1, "parryBonus": 100 } );
						var weapon = { "name": "Shortbow", "category": "ranged", "damageDice": "1d6", "damageType": "Piercing", "attackBonus": 100, "damageBonus": 0 };
						service.resolveAttack( log, { "name": "Attacker" }, defender, weapon, false );
						expect( log[ 1 ] ).notToInclude( "Parried" );
					}
				} );
			} );

			describe( "legendary actions (endPlayerTurn())", () => {
				function makeLegendaryState( opponentExtra, playerExtra = {} ){
					return {
						"player": makeCombatant( 1, 1, { "name": "Test Hero", "inventory": [] }.append( arguments.playerExtra ) ),
						"opponent": makeCombatant( 2, 1, { "name": "Test Boss", "inventory": [], "hitPoints": 100, "maxHitPoints": 200 }.append( arguments.opponentExtra ) ),
						"movementRemaining": 6, "actionUsed": false, "gameOver": false, "outcome": "", "log": [], "round": 1, "currentTurn": "enemy"
					};
				}

				it( "reuses a named weapon attack for a 'makes one X attack' legendary action", () => {
					var state = makeLegendaryState( {
						"inventory": [ { "name": "Rend", "category": "melee", "damageDice": "2d6", "damageType": "Slashing", "attackBonus": 100, "damageBonus": 5, "equipped": false } ],
						"legendaryActions": [ {
							"name": "Tail Swipe", "desc": "Tail Swipe. The dragon makes one Rend attack.",
							"attackBonus": 0, "damageDice": "", "damageBonus": 0, "damageType": "", "category": "",
							"saveAbility": "", "saveAbilityLabel": "", "saveDC": 0, "rangeSquares": 0, "healAmount": 0
						} ]
					} );
					service.endPlayerTurn( state );
					expect( state.player.hitPoints ).toBeLT( 500 );
					expect( state.log[ 1 ] ).toInclude( "legendary action: Tail Swipe" );
				} );

				it( "resolves a save-based legendary attack (e.g. a breath-weapon-style effect)", () => {
					var state = makeLegendaryState( {
						"legendaryActions": [ {
							"name": "Cloud of Insects", "desc": "Dexterity Saving Throw: DC 100.",
							"attackBonus": 0, "damageDice": "4d6", "damageBonus": 0, "damageType": "Poison", "category": "",
							"saveAbility": "dex", "saveAbilityLabel": "Dexterity", "saveDC": 100, "rangeSquares": 10, "healAmount": 0
						} ]
					}, { "modifiers": { "dex": 0 }, "proficiencyBonus": 0 } );
					// DC 100 is unreachable by any roll, so the save always fails and full damage always lands.
					service.endPlayerTurn( state );
					var damageTaken = 500 - state.player.hitPoints;
					expect( damageTaken >= 4 && damageTaken <= 24 ).toBeTrue();
					expect( state.log[ 1 ] ).toInclude( "legendary action: Cloud of Insects" );
				} );

				it( "heals the monster via a healAmount legendary action", () => {
					var state = makeLegendaryState( {
						"legendaryActions": [ {
							"name": "Psychic Drain", "desc": "Regains Hit Points.",
							"attackBonus": 0, "damageDice": "", "damageBonus": 0, "damageType": "", "category": "",
							"saveAbility": "", "saveAbilityLabel": "", "saveDC": 0, "rangeSquares": 0, "healAmount": 10
						} ]
					} );
					service.endPlayerTurn( state );
					expect( state.opponent.hitPoints ).toBe( 110 );
				} );

				it( "logs a flavor-only legendary action when nothing is mechanically resolvable", () => {
					var state = makeLegendaryState( {
						"legendaryActions": [ {
							"name": "Cloaked Flight", "desc": "The dragon uses Spellcasting to cast Invisibility on itself.",
							"attackBonus": 0, "damageDice": "", "damageBonus": 0, "damageType": "", "category": "",
							"saveAbility": "", "saveAbilityLabel": "", "saveDC": 0, "rangeSquares": 0, "healAmount": 0
						} ]
					} );
					service.endPlayerTurn( state );
					expect( state.player.hitPoints ).toBe( 500 );
					expect( state.opponent.hitPoints ).toBe( 100 );
					expect( state.log[ 1 ] ).toInclude( "legendary action: Cloaked Flight" );
				} );

				it( "does nothing for an opponent with no legendary actions", () => {
					var state = makeLegendaryState( { "legendaryActions": [] } );
					var logLenBefore = state.log.len();
					service.endPlayerTurn( state );
					for ( var entry in state.log ) {
						expect( entry ).notToInclude( "legendary action" );
					}
				} );
			} );

			describe( "playerDecideAndAct() / runEnemyTurn() / endPlayerTurn() turn bookkeeping", () => {
				function makeState(){
					return {
						"player": makeCombatant( 1, 1, {
							"characterId": -1, // no such row — these tests never reduce HP to 0, so awardExperience() never fires
							"name": "Test Hero",
							"inventory": [ { "name": "Greatsword", "category": "melee", "damageDice": "2d6", "damageType": "Slashing", "attackBonus": 100, "damageBonus": 2, "equipped": true } ]
						} ),
						"opponent": makeCombatant( 20, 20, {
							"name": "Test Dummy",
							"xp": 10,
							"inventory": [ { "name": "Club", "category": "melee", "damageDice": "1d4", "damageType": "Bludgeoning", "attackBonus": 100, "damageBonus": 1, "equipped": true } ]
						} ),
						"movementRemaining": 6,
						"actionUsed": false,
						"gameOver": false,
						"outcome": "",
						"log": [],
						"round": 1,
						"currentTurn": "player"
					};
				}

				it( "advances the player toward the opponent when not adjacent, without attacking", () => {
					var state = makeState();
					service.playerDecideAndAct( state );
					// Distance starts at 19 (Chebyshev), farther than the 6-square move budget.
					expect( state.movementRemaining ).toBe( 0 );
					expect( state.player.position.x ).toBe( 7 );
					expect( state.player.position.y ).toBe( 7 );
					expect( state.actionUsed ).toBeFalse();
				} );

				it( "attacks instead of moving once adjacent", () => {
					var state = makeState();
					state.player.position = { "x": 19, "y": 20 };
					service.playerDecideAndAct( state );
					expect( state.actionUsed ).toBeTrue();
					expect( state.player.position.x ).toBe( 19 );
					expect( state.log.len() ).toBe( 1 );
				} );

				it( "hands off to the enemy and resets for the next player turn", () => {
					var state = makeState();
					state.currentTurn = "enemy";
					service.endPlayerTurn( state );
					expect( state.round ).toBe( 2 );
					expect( state.currentTurn ).toBe( "player" );
					expect( state.actionUsed ).toBeFalse();
					expect( state.movementRemaining ).toBe( 6 );
					expect( state.gameOver ).toBeFalse();
				} );

				it( "runEnemyTurn() closes the distance and attacks once adjacent", () => {
					var state = makeState();
					state.opponent.position = { "x": 2, "y": 1 };
					service.runEnemyTurn( state );
					expect( state.log.len() ).toBeGTE( 1 );
				} );
			} );

			describe( "multi-mob encounters", () => {
				function makeMultiMobState(){
					var player = makeCombatant( 1, 1, {
						"characterId": -1,
						"name": "Test Hero",
						"inventory": [ { "name": "Greatsword", "category": "melee", "damageDice": "2d6", "damageType": "Slashing", "attackBonus": 100, "damageBonus": 2, "equipped": true } ]
					} );
					var mobA = makeCombatant( 2, 1, { "name": "Mob A", "xp": 10, "hitPoints": 1, "mobIndex": 1, "inventory": [] } );
					var mobB = makeCombatant( 1, 2, { "name": "Mob B", "xp": 10, "hitPoints": 500, "mobIndex": 2, "inventory": [] } );
					return {
						"player": player, "opponents": [ mobA, mobB ], "opponent": mobA,
						"movementRemaining": 6, "actionUsed": false, "gameOver": false, "outcome": "",
						"log": [], "round": 1, "currentTurn": "player"
					};
				}

				// attackBonus 100 guarantees a hit vs. AC 10 on any non-fumble
				// roll, but a natural 1 always misses regardless of bonus —
				// so retry a few times on the same state (a miss changes
				// nothing) rather than risk a ~5% flake on a single roll.
				function attackUntilHit( state ){
					for ( var attempt = 1; attempt <= 20 && arguments.state.opponents[ 1 ].hitPoints > 0; attempt++ ) {
						service.playerAttack( arguments.state, arguments.state.player.inventory[ 1 ], false );
					}
				}

				it( "downing one mob doesn't end the encounter while others remain", () => {
					var state = makeMultiMobState();
					attackUntilHit( state );
					expect( state.gameOver ).toBeFalse();
					expect( state.opponents[ 1 ].hitPoints ).toBe( 0 );
					expect( state.opponents[ 2 ].hitPoints ).toBeGT( 0 );
				} );

				it( "auto-retargets to the next living mob once the current target is downed", () => {
					var state = makeMultiMobState();
					attackUntilHit( state );
					expect( state.opponent.name ).toBe( "Mob B" );
				} );

				it( "only ends the encounter in victory once every mob is downed", () => {
					var state = makeMultiMobState();
					state.opponents[ 2 ].hitPoints = 1; // both mobs now one hit from death
					attackUntilHit( state ); // downs Mob A, retargets to Mob B
					expect( state.gameOver ).toBeFalse();

					for ( var attempt = 1; attempt <= 20 && !state.gameOver; attempt++ ) {
						service.playerAttack( state, state.player.inventory[ 1 ], false ); // downs Mob B too
					}
					expect( state.gameOver ).toBeTrue();
					expect( state.outcome ).toBe( "victory" );
				} );

				it( "runEnemyTurn() runs every living mob's turn, skipping downed ones", () => {
					var state = makeMultiMobState();
					state.opponents[ 1 ].hitPoints = 0; // Mob A already down
					state.opponents[ 2 ].position = { "x": 2, "y": 1 }; // adjacent to the player
					service.runEnemyTurn( state );
					// Only Mob B (still alive, adjacent) should have acted — a
					// "notices you" entry plus its attack, both about Mob B;
					// nothing at all from downed Mob A.
					expect( state.log.len() ).toBe( 2 );
					for ( var entry in state.log ) {
						expect( entry ).toInclude( "Mob B" );
					}
				} );
			} );

			describe( "death saving throws", () => {
				function makeDyingPlayerState( extra = {} ){
					var player = makeCombatant( 1, 1, {
						"name": "Test Hero", "hitPoints": 0, "maxHitPoints": 10,
						"isDying": true, "deathSaveSuccesses": 0, "deathSaveFailures": 0
					}.append( arguments.extra ) );
					return { "player": player, "log": [], "gameOver": false, "outcome": "" };
				}

				it( "dropping to 0 HP starts dying instead of ending the encounter", () => {
					var player = makeCombatant( 1, 1, { "hitPoints": 1, "maxHitPoints": 10 } );
					var mob = makeCombatant( 2, 1, {
						"name": "Mob", "hitPoints": 10, "mobIndex": 1,
						"inventory": [ { "name": "Club", "category": "melee", "damageDice": "1d4", "damageType": "Bludgeoning", "attackBonus": 100, "damageBonus": 0, "equipped": true } ]
					} );
					var state = { "player": player, "opponents": [ mob ], "opponent": mob, "log": [], "gameOver": false, "outcome": "" };

					// attackBonus 100 guarantees a hit vs. AC 10 on any non-fumble
					// roll, but a natural 1 always misses regardless of bonus — a
					// miss leaves the player's HP (and the mob's fresh turn) exactly
					// as it was, so retrying is safe (same pattern as attackUntilHit()
					// in the multi-mob encounters above).
					for ( var attempt = 1; attempt <= 20 && player.hitPoints > 0; attempt++ ) {
						service.runEnemyTurn( state );
					}

					expect( state.gameOver ).toBeFalse();
					expect( player.hitPoints ).toBe( 0 );
					expect( player.isDying ).toBeTrue();
				} );

				it( "rollDeathSave() is a no-op when the player isn't dying", () => {
					var state = makeDyingPlayerState( { "isDying": false } );
					service.rollDeathSave( state );
					expect( state.log.len() ).toBe( 0 );
				} );

				it( "reaching 3 failures ends the encounter in defeat", () => {
					var state = makeDyingPlayerState( { "deathSaveFailures": 2 } );
					for ( var attempt = 1; attempt <= 200 && !state.gameOver; attempt++ ) {
						service.rollDeathSave( state );
						if ( state.gameOver ) {
							break;
						}
						// Any non-terminal roll (a success, or a natural-20 revive) is
						// pinned back to "2 failures, still dying" so this test isolates
						// the failure path instead of racing the success path to 3 —
						// otherwise three lucky successes in a row would stabilize the
						// player before a third failure ever lands.
						state.player.isDying = true;
						state.player.hitPoints = 0;
						state.player.deathSaveFailures = 2;
						state.player.deathSaveSuccesses = 0;
					}
					expect( state.gameOver ).toBeTrue();
					expect( state.outcome ).toBe( "defeat" );
				} );

				it( "reaching 3 successes stabilizes the player without ending the encounter", () => {
					var state = makeDyingPlayerState( { "deathSaveSuccesses": 2 } );
					var stabilized = false;
					for ( var attempt = 1; attempt <= 200 && !stabilized && !state.gameOver; attempt++ ) {
						service.rollDeathSave( state );
						stabilized = structKeyExists( state.player, "isStable" ) && state.player.isStable;
						if ( stabilized || state.gameOver ) {
							break;
						}
						// Same reasoning as above, mirrored: pin back to "2 successes,
						// still dying" after any non-terminal roll so this isolates the
						// success path instead of racing failures to 3.
						state.player.isDying = true;
						state.player.hitPoints = 0;
						state.player.deathSaveSuccesses = 2;
						state.player.deathSaveFailures = 0;
					}
					expect( state.gameOver ).toBeFalse();
					expect( stabilized ).toBeTrue();
				} );

				it( "a hit against a dying player counts as automatic death save failures instead of rolling to hit", () => {
					var state = makeDyingPlayerState();
					var mob = makeCombatant( 2, 1, {
						"name": "Mob", "hitPoints": 10, "mobIndex": 1,
						"inventory": [ { "name": "Club", "category": "melee", "damageDice": "1d4", "damageType": "Bludgeoning", "attackBonus": 100, "damageBonus": 0, "equipped": true } ]
					} );
					state.opponents = [ mob ];
					state.opponent = mob;

					service.runEnemyTurn( state );

					// Adjacent (1 square away) counts as an automatic critical: 2 failures.
					expect( state.player.deathSaveFailures ).toBe( 2 );
					expect( state.gameOver ).toBeFalse();
				} );
			} );

			describe( "attacksPerTurn()", () => {
				it( "is 1 with no Extra Attack feature", () => {
					expect( service.attacksPerTurn( makeCombatant( 0, 0, { "features": [ "Second Wind" ] } ) ) ).toBe( 1 );
					expect( service.attacksPerTurn( makeCombatant( 0, 0 ) ) ).toBe( 1 );
				} );

				it( "adds one attack per Extra Attack tier, additively", () => {
					expect( service.attacksPerTurn( makeCombatant( 0, 0, { "features": [ "Extra Attack" ] } ) ) ).toBe( 2 );
					expect( service.attacksPerTurn( makeCombatant( 0, 0, { "features": [ "Extra Attack", "Two Extra Attacks" ] } ) ) ).toBe( 3 );
					expect( service.attacksPerTurn( makeCombatant( 0, 0, { "features": [ "Extra Attack", "Two Extra Attacks", "Three Extra Attacks" ] } ) ) ).toBe( 4 );
				} );
			} );

			describe( "startNewRound()", () => {
				it( "resets movement, action economy, and every combatant's reaction", () => {
					var player = makeCombatant( 1, 1, { "speed": 30 } );
					var mob = makeCombatant( 2, 1, { "name": "Mob", "reactionUsed": true } );
					var state = {
						"player": player, "opponents": [ mob ], "movementRemaining": 0,
						"actionUsed": true, "bonusActionUsed": true, "attacksUsedThisTurn": 3
					};
					player.reactionUsed = true;

					service.startNewRound( state );

					expect( state.movementRemaining ).toBe( 6 );
					expect( state.actionUsed ).toBeFalse();
					expect( state.bonusActionUsed ).toBeFalse();
					expect( state.attacksUsedThisTurn ).toBe( 0 );
					expect( player.reactionUsed ).toBeFalse();
					expect( mob.reactionUsed ).toBeFalse();
				} );
			} );

			describe( "playerDecideAndAct() with Extra Attack", () => {
				it( "attacks twice in one turn for a combatant with Extra Attack", () => {
					var player = makeCombatant( 1, 1, {
						"features": [ "Extra Attack" ],
						"inventory": [ { "name": "Sword", "category": "melee", "damageDice": "1d1", "damageType": "Slashing", "attackBonus": 100, "damageBonus": 0, "equipped": true } ]
					} );
					var mob = makeCombatant( 2, 1, { "name": "Mob", "hitPoints": 500, "mobIndex": 1 } );
					var state = {
						"player": player, "opponents": [ mob ], "opponent": mob, "movementRemaining": 6,
						"actionUsed": false, "attacksUsedThisTurn": 0, "gameOver": false, "outcome": "", "log": []
					};

					service.playerDecideAndAct( state );

					expect( state.attacksUsedThisTurn ).toBe( 2 );
					// attackBonus 100 vs AC 10 always hits (barring a natural 1 on
					// either roll) for 1 damage each with a 1-sided die.
					expect( 500 - mob.hitPoints ).toBeGTE( 0 );
				} );
			} );

			describe( "checkOpportunityAttacks()", () => {
				it( "lets a hostile with a melee weapon strike a combatant who moves out of its reach", () => {
					var mover = makeCombatant( 5, 1, {
						"name": "Mover",
						"inventory": [ { "name": "Fists", "category": "melee", "damageDice": "1d1", "damageType": "Bludgeoning", "attackBonus": -50, "damageBonus": 0, "equipped": true } ]
					} );
					var hostile = makeCombatant( 6, 1, {
						"name": "Hostile",
						"inventory": [ { "name": "Club", "category": "melee", "damageDice": "1d4", "damageType": "Bludgeoning", "attackBonus": 100, "damageBonus": 0, "equipped": true } ]
					} );
					var state = { "player": mover, "opponents": [ hostile ], "log": [], "gameOver": false, "outcome": "" };
					var startPosition = { "x": 5, "y": 1 };
					mover.position = { "x": 1, "y": 1 }; // moved 4 squares away, out of reach

					service.checkOpportunityAttacks( state, mover, true, startPosition );

					// One "makes an opportunity attack" log entry, plus resolveAttack()'s
					// own hit/miss entry for the actual roll.
					expect( state.log.len() ).toBe( 2 );
					expect( state.log[ 2 ] ).toInclude( "opportunity attack" );
					expect( hostile.reactionUsed ).toBeTrue();
				} );

				it( "doesn't trigger if the mover is still adjacent to the hostile", () => {
					var mover = makeCombatant( 5, 1, { "name": "Mover", "inventory": [] } );
					var hostile = makeCombatant( 6, 1, { "name": "Hostile", "inventory": [ { "name": "Club", "category": "melee", "damageDice": "1d4", "damageType": "Bludgeoning", "attackBonus": 100, "damageBonus": 0, "equipped": true } ] } );
					var state = { "player": mover, "opponents": [ hostile ], "log": [], "gameOver": false, "outcome": "" };
					var startPosition = { "x": 5, "y": 1 };
					mover.position = { "x": 5, "y": 2 }; // still adjacent to (6,1)

					service.checkOpportunityAttacks( state, mover, true, startPosition );

					expect( state.log.len() ).toBe( 0 );
				} );

				it( "doesn't trigger if the hostile has no melee weapon, is downed, or already used its Reaction", () => {
					var mover = makeCombatant( 5, 1, { "name": "Mover", "inventory": [] } );
					var unarmed = makeCombatant( 6, 1, { "name": "Unarmed", "inventory": [] } );
					var downed = makeCombatant( 6, 2, { "name": "Downed", "hitPoints": 0, "inventory": [ { "name": "Club", "category": "melee", "damageDice": "1d4", "damageType": "Bludgeoning", "attackBonus": 100, "damageBonus": 0, "equipped": true } ] } );
					var spent = makeCombatant( 4, 1, { "name": "Spent", "reactionUsed": true, "inventory": [ { "name": "Club", "category": "melee", "damageDice": "1d4", "damageType": "Bludgeoning", "attackBonus": 100, "damageBonus": 0, "equipped": true } ] } );
					var state = { "player": mover, "opponents": [ unarmed, downed, spent ], "log": [] };
					var startPosition = { "x": 5, "y": 1 };
					mover.position = { "x": 1, "y": 1 };

					service.checkOpportunityAttacks( state, mover, true, startPosition );

					expect( state.log.len() ).toBe( 0 );
				} );

				it( "works in reverse too: the player can make an opportunity attack when a mob moves away", () => {
					var opponentMover = makeCombatant( 5, 1, { "name": "Mover", "inventory": [] } );
					var playerHostile = makeCombatant( 6, 1, {
						"name": "Hero",
						"inventory": [ { "name": "Sword", "category": "melee", "damageDice": "1d6", "damageType": "Slashing", "attackBonus": 100, "damageBonus": 0, "equipped": true } ]
					} );
					var state = { "player": playerHostile, "opponents": [ opponentMover ], "log": [], "gameOver": false, "outcome": "" };
					var startPosition = { "x": 5, "y": 1 };
					opponentMover.position = { "x": 1, "y": 1 };

					service.checkOpportunityAttacks( state, opponentMover, false, startPosition );

					expect( state.log.len() ).toBe( 2 );
					expect( state.log[ 1 ] ).toInclude( "Hero" );
				} );
			} );

			describe( "applyAbilityScoreImprovement()", () => {
				function makePendingAsiState( abilityScores = {} ){
					var player = makeCombatant( 0, 0, {
						"abilityScores": { "str": 10, "dex": 10, "con": 10, "int": 10, "wis": 10, "cha": 10 }.append( arguments.abilityScores ),
						"modifiers": { "str": 0, "dex": 0, "con": 0, "int": 0, "wis": 0, "cha": 0 },
						"armorClass": 10, "pendingAbilityScoreImprovements": 1
					} );
					return { "player": player, "log": [] };
				}

				it( "is a no-op when there's no pending improvement", () => {
					var state = makePendingAsiState();
					state.player.pendingAbilityScoreImprovements = 0;
					service.applyAbilityScoreImprovement( state, { "abilities": [ "str" ] } );
					expect( state.player.abilityScores.str ).toBe( 10 );
					expect( state.log.len() ).toBe( 0 );
				} );

				it( "applies +2 to a single chosen ability and consumes the pending improvement", () => {
					var state = makePendingAsiState();
					service.applyAbilityScoreImprovement( state, { "abilities": [ "str" ] } );
					expect( state.player.abilityScores.str ).toBe( 12 );
					expect( state.player.modifiers.str ).toBe( 1 );
					expect( state.player.pendingAbilityScoreImprovements ).toBe( 0 );
				} );

				it( "applies +1 to each of two chosen abilities", () => {
					var state = makePendingAsiState();
					service.applyAbilityScoreImprovement( state, { "abilities": [ "str", "dex" ] } );
					expect( state.player.abilityScores.str ).toBe( 11 );
					expect( state.player.abilityScores.dex ).toBe( 11 );
					expect( state.player.pendingAbilityScoreImprovements ).toBe( 0 );
				} );

				it( "caps an ability at 20", () => {
					var state = makePendingAsiState( { "str": 19 } );
					service.applyAbilityScoreImprovement( state, { "abilities": [ "str" ] } );
					expect( state.player.abilityScores.str ).toBe( 20 );
				} );

				it( "increases Dexterity's modifier bump into armor class", () => {
					var state = makePendingAsiState();
					service.applyAbilityScoreImprovement( state, { "abilities": [ "dex" ] } );
					expect( state.player.armorClass ).toBe( 11 );
				} );

				it( "bumps an equipped weapon's attack/damage bonus to match the improved ability", () => {
					var state = makePendingAsiState();
					state.player.inventory = [ { "name": "Sword", "category": "melee", "equipped": true, "attackBonus": 2, "damageBonus": 0, "id": 42 } ];
					service.applyAbilityScoreImprovement( state, { "abilities": [ "str" ] } );
					expect( state.player.inventory[ 1 ].attackBonus ).toBe( 3 );
					expect( state.player.inventory[ 1 ].damageBonus ).toBe( 1 );
				} );

				it( "ignores an invalid number of abilities", () => {
					var state = makePendingAsiState();
					service.applyAbilityScoreImprovement( state, { "abilities": [ "str", "dex", "con" ] } );
					expect( state.player.abilityScores.str ).toBe( 10 );
					expect( state.player.pendingAbilityScoreImprovements ).toBe( 1 );
				} );
			} );

			describe( "isFullCasterClass()", () => {
				it( "is true for each of the six full-caster classes", () => {
					for ( var className in [ "Bard", "Cleric", "Druid", "Sorcerer", "Warlock", "Wizard" ] ) {
						expect( service.isFullCasterClass( className ) ).toBeTrue();
					}
				} );

				it( "is false for half-casters and non-casters", () => {
					for ( var className in [ "Paladin", "Ranger", "Fighter", "Barbarian", "Rogue", "Monk" ] ) {
						expect( service.isFullCasterClass( className ) ).toBeFalse();
					}
				} );
			} );

		} );
	}

}
